# API Configuration
# API Gateway URL - all services are proxied through this single endpoint
VITE_API_BASE_URL=http://localhost:4000/api

# Optional: Set individual service URLs (overrides VITE_API_BASE_URL if needed)
# VITE_API_URL=http://localhost:4000/api
# VITE_AUTH_URL=http://localhost:4001/auth
# VITE_PATIENT_URL=http://localhost:4002/patients
# VITE_DOCTOR_URL=http://localhost:4003/doctor
# VITE_APPOINTMENT_URL=http://localhost:4004/appointments

# Application
VITE_APP_NAME=Medora
VITE_APP_VERSION=1.0.0
